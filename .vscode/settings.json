{
  "latex-workshop.latex.outDir": "./build",
  "latex-workshop.latex.recipe.default": "pdflatex-biber-build",
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex-biber-build",
      "tools": ["pdflatex", "biber", "pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-interaction=nonstopmode",
        "-output-directory=build",
        "%DOCFILE%"
      ]
    },
    {
      "name": "biber",
      "command": "biber",
      "args": [
        "--input-directory",
        "build",
        "--output-directory",
        "build",
        "%DOCFILE%"
      ]
    }
  ]
}